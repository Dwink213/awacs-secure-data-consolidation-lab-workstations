                      "query": "StorageBlobLogs\n| where OperationName == \"PutBlob\"\n| extend hostname = tostring(split(ObjectKey, \"/\")[0])\n| summarize lastSeen = max(TimeGenerated) by hostname\n| where lastSeen < ago(25h)\n",
